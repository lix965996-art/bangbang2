# 生产环境配置示例
# 复制为 .env.production 后按实际部署地址修改

# 后端服务地址
VUE_APP_API_BASE_URL=http://your-server-ip:9090
VUE_APP_AMAP_JS_KEY=your_amap_js_key_here
VUE_APP_AMAP_SECURITY_CODE=your_amap_security_code_here

# 应用名称
VUE_APP_NAME=BangBangAgro智慧农场

# 界面模式
# competition: 国赛展示版，只保留核心导航
# full: 完整后台版，显示全部菜单
VUE_APP_SHOWCASE_MODE=competition

# 构建输出目录
VUE_APP_OUTPUT_DIR=dist
