# 智慧农场管理系统环境变量配置示例
# ======================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart-agriculture
DB_USERNAME=root
DB_PASSWORD=123456

# API密钥配置
QWEN_API_KEY=your_qwen_api_key_here  # 通义千问API密钥
AMAP_JS_KEY=your_amap_js_key_here    # 高德地图JavaScript API密钥
AMAP_WEB_KEY=your_amap_web_key_here  # 高德地图Web服务API密钥
AMAP_JS_SECURITY_KEY=your_amap_js_security_key_here  # 高德地图安全码

# OneNET物联网平台配置
ONENET_AUTHOR_KEY=your_onenet_author_key_here  # OneNET API密钥
ONENET_USER_ID=your_onenet_user_id_here        # OneNET用户ID
ONENET_VERSION=2022-05-01                      # OneNET API版本（可选）
ONENET_PRODUCT_ID=your_onenet_product_id_here  # OneNET产品ID
ONENET_DEVICE_NAME=your_onenet_device_name_here  # OneNET设备名称
ONENET_NEW_PRODUCT_ID=your_new_product_id_here   # 新设备产品ID（可选）
ONENET_NEW_DEVICE_NAME=your_new_device_name_here  # 新设备名称（可选）
ONENET_ENABLED=true                            # OneNET功能总开关

# Python检测服务（可选）
PYTHON_API_URL=http://localhost:5000

# 服务器配置
SERVER_DOMAIN=http://localhost:9090

# 文件上传配置
UPLOAD_PATH=C:/Users/Swift/smart-agriculture-uploads/

# 日志配置
LOG_LEVEL=info

# ==============================
# 生产环境必须设置以下变量
# ==============================
# QWEN_API_KEY: 必须设置，否则应用无法启动
# AMAP_JS_KEY 或 AMAP_WEB_KEY: 至少设置一个
# AMAP_JS_SECURITY_KEY: 前端地图页面建议同时设置
# ONENET_AUTHOR_KEY: 物联网功能必须设置

# ==============================
# 开发环境可以使用默认值
# ==============================
# DB_PASSWORD: 123456 (默认)
# PYTHON_API_URL: http://localhost:5000 (默认)
# SERVER_DOMAIN: http://localhost:9090 (默认)
