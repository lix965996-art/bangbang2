# 应用配置
app:
  # 应用标识
  bundleName: com.smartfarm.app

  # 版本信息
  version:
    name: 1.0.0
    code: 100

  # API版本
  apiVersion:
    compatible: 9
    target: 9
    releaseType: Release

# 网络配置
network:
  # 安全域名配置
  securityConfig:
    domainSettings:
      domains:
        - name: restapi.amap.com
          includeSubdomains: true
        - name: dashscope.aliyuncs.com
          includeSubdomains: true
